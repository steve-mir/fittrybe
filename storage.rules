// storage.rules
// Deploy with: firebase deploy --only storage

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Blog images — public read, authenticated write
    match /blog-images/{filename} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024  // 5 MB limit
        && request.resource.contentType.matches('image/.*');
    }
  }
}
